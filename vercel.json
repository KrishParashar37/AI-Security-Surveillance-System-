{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "http://your-backend-url.com/api/$1" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ],
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/frontend/$1",
      "check": true
    },
    {
      "src": "/(.*)",
      "status": 200,
      "dest": "/frontend/index.html"
    }
  ]
}
